# Database (used later in full app expansion)
DATABASE_URL=postgresql+asyncpg://bangladoc:bangladoc@localhost:5432/bangladoc
REDIS_URL=redis://localhost:6379/0

# JWT secret for API modules
SECRET_KEY=CHANGE_ME_BEFORE_FIRST_RUN
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Ollama OCR fallback + image descriptions
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_IMAGE_MODEL=moondream2

# Gemini fallback (optional)
GEMINI_API_KEY=
GEMINI_ENABLED=false

# Performance (Mac Mini M4 tuned)
USE_GPU=false
MAX_WORKERS=2
DPI=200
LOG_LEVEL=INFO
# Relative paths are resolved from the project root (Varnoq System), not your shell cwd.
DATA_DIR=../data

# OCR controls
SURYA_ENABLED=true
# Strict OCR chain from SURYA_ENABLED only:
# true  => surya -> ollama -> gemini -> easyocr
# false => ollama -> gemini -> easyocr
# Script guard for Surya Bangla pipeline
SURYA_MIN_BANGLA_RATIO=0.12
SURYA_DEVANAGARI_REJECT_THRESHOLD=0.18
OCR_MIN_BANGLA_RATIO=0.10
OCR_DEVANAGARI_REJECT_THRESHOLD=0.16

# Apple Silicon
PYTORCH_ENABLE_MPS_FALLBACK=1

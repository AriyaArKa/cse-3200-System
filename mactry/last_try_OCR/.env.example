# -- Gemini (optional cloud fallback - free tier) ---------------------
GEMINI_API_KEY=
GEMINI_ENABLED=false

# -- Ollama (local LLM, primary fallback) -----------------------------
OLLAMA_BASE_URL=http://localhost:11434
USE_OLLAMA_FIRST=true

# -- Processing --------------------------------------------------------
FAST_MODE=false
FAST_MODE_BANGLA=true
LOG_LEVEL=INFO
DISABLE_MP=false

# -- Hardware ----------------------------------------------------------
USE_GPU=false
# Set USE_GPU=true only if torch.backends.mps.is_available() returns True
# EasyOCR will use MPS on M4 if USE_GPU=true

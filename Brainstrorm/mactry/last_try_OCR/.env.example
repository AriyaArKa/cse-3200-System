# ── Gemini (optional — free tier, gemini-2.0-flash) ──────────────────────
GEMINI_API_KEY=
GEMINI_ENABLED=false

# ── Ollama (local LLM, primary fallback) ─────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434

# ── Processing ────────────────────────────────────────────────────────────
FAST_MODE=false
FAST_MODE_BANGLA=true
LOG_LEVEL=INFO

# ── Hardware ──────────────────────────────────────────────────────────────
# Set USE_GPU=true to enable MPS on Apple Silicon M4.
# Test first: python3 -c "import torch; print(torch.backends.mps.is_available())"
USE_GPU=false
